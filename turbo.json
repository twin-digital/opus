{
  "$schema": "./node_modules/turbo/schema.json",
  "concurrency": "2",
  "globalPassThroughEnv": ["CI"],
  "globalDependencies": [
    ".prettierrc",
    ".prettierignore",
    "nodejs/devtools/tsconfig/tsconfig.json",
    "nodejs/devtools/tsconfig/tsconfig.build.json"
  ],
  "tasks": {
    "artifact": {
      "dependsOn": ["build"],
      "inputs": ["assets/**", "Dockerfile", "package.json", "src/**", "tsconfig.json", "tsconfig.*.json"],
      "outputs": [".out/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "assets/**",
        "index.html",
        "pack/**",
        "package.json",
        "src/**",
        "tsconfig.json",
        "tsconfig.*.json",
        "tsdown.config.ts",
        "tsdown.config.d/**",
        "vite.config.ts",
        "vite.config.d/**"
      ],
      "outputs": ["dist/**"]
    },
    "clean": {
      "cache": false
    },
    "deploy:serverless": {
      "cache": false,
      "dependsOn": ["build", "^deploy:serverless"],
      "passThroughEnv": ["AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY", "AWS_SESSION_TOKEN", "SERVERLESS_ACCESS_KEY"]
    },
    "deploy:cdk": {
      "cache": false,
      "dependsOn": ["build", "^deploy:cdk"],
      "passThroughEnv": ["AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY", "AWS_SESSION_TOKEN"]
    },
    "destroy:serverless": {
      "cache": false,
      "passThroughEnv": ["AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY", "AWS_SESSION_TOKEN", "SERVERLESS_ACCESS_KEY"]
    },
    "destroy:cdk": {
      "cache": false,
      "passThroughEnv": ["AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY", "AWS_SESSION_TOKEN"]
    },
    "lint": {
      "dependsOn": ["upstream-sources", "@twin-digital/eslint-config#build", "//#lint:deps"],
      "inputs": ["eslint.config.js", "package.json", "src/**"]
    },
    "@twin-digital/credential-shelf-trigger#lint": {
      "dependsOn": ["upstream-sources", "@twin-digital/eslint-config#build", "//#lint:deps", "build"],
      "inputs": ["eslint.config.js", "package.json", "src/**", "bin/**"]
    },
    "lint:fix": {
      "cache": false,
      "dependsOn": ["upstream-sources", "@twin-digital/eslint-config#build"]
    },
    "//#lint:deps": {
      "inputs": ["**/package.json", "pnpm-workspace.yaml"]
    },
    "release-assets": {
      "cache": false,
      "dependsOn": ["build"]
    },
    "test": {
      "dependsOn": ["upstream-sources", "@twin-digital/vitest-config#build"],
      "inputs": ["src/**", "package.json", "vitest.config.ts", "tsconfig.json", "tsconfig.*.json"],
      "outputs": ["coverage.json"]
    },
    "test:watch": {
      "dependsOn": ["@twin-digital/vitest-config#build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["upstream-sources"],
      "inputs": ["package.json", "tsconfig.json", "tsconfig.*.json", "src/**"],
      "outputs": []
    },
    "@twin-digital/credential-shelf#typecheck": {
      "dependsOn": ["upstream-sources", "build"],
      "inputs": ["package.json", "tsconfig.json", "tsconfig.*.json", "src/**", "bin/**"],
      "outputs": []
    },
    "@twin-digital/credential-shelf-trigger#typecheck": {
      "dependsOn": ["upstream-sources", "build"],
      "inputs": ["package.json", "tsconfig.json", "tsconfig.*.json", "src/**", "bin/**"],
      "outputs": []
    },
    "upstream-sources": {
      "dependsOn": ["^upstream-sources"]
    },
    "watch": {
      "cache": false,
      "dependsOn": ["^build"],
      "persistent": true
    }
  }
}
