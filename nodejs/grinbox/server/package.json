{
  "private": true,
  "name": "@twin-digital/grinbox-server",
  "version": "0.0.0",
  "description": "Grinbox daemon: HTTP API, pipeline runtime, and mail polling.",
  "license": "ISC",
  "type": "module",
  "exports": {
    "./*": {
      "import": {
        "source": "./src/*.ts",
        "types": "./dist/*.d.ts",
        "import": "./dist/*.js"
      }
    },
    ".": {
      "import": {
        "source": "./src/index.ts",
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "./index": null,
    "./index.js": null
  },
  "files": [
    "dist",
    "!dist/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "build",
    "clean": "clean",
    "dev": "tsx watch --conditions=source src/main.ts",
    "lint": "lint",
    "lint:fix": "lint_fix",
    "seed:demo": "tsx --conditions=source src/scripts/seed-demo.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "catalog:",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.8.0",
    "@twin-digital/grinbox-shared": "workspace:*",
    "better-sqlite3": "^11.8.0",
    "croner": "^9.0.0",
    "googleapis": "^144.0.0",
    "hono": "catalog:",
    "kysely": "^0.27.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@twin-digital/eslint-config": "workspace:*",
    "@twin-digital/opus-scripts": "workspace:*",
    "@twin-digital/tsconfig": "workspace:*",
    "@twin-digital/vitest-config": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "prettier-package-json": "catalog:",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "10.x"
  }
}
