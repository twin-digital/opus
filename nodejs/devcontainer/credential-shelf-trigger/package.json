{
  "private": true,
  "name": "@twin-digital/credential-shelf-trigger",
  "version": "0.2.2",
  "description": "Network-facing trigger for the credential-shelf remote refresh — an authenticated, rate-limited, LAN-local endpoint that drives the sidecar's device-code refresh primitive over a Unix socket. Holds no AWS identity.",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "source": "./src/index.ts",
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "./index": null,
    "./index.js": null,
    "./*": {
      "import": {
        "source": "./src/*.ts",
        "types": "./dist/*.d.ts",
        "import": "./dist/*.js"
      }
    }
  },
  "bin": {
    "credential-shelf-trigger": "./bin/run.js"
  },
  "files": [
    "bin",
    "dist",
    "!dist/**/*.d.ts.map"
  ],
  "scripts": {
    "artifact": "artifact",
    "build": "build",
    "clean": "clean",
    "lint": "lint",
    "lint:fix": "lint_fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@twin-digital/eslint-config": "workspace:*",
    "@twin-digital/opus-scripts": "workspace:*",
    "@twin-digital/tsconfig": "workspace:*",
    "@twin-digital/tsdown-config": "workspace:*",
    "@twin-digital/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "prettier-package-json": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "11.x"
  }
}
