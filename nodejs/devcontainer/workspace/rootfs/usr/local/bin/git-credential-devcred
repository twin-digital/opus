#!/usr/bin/env bash
#
# git credential helper → the vended GitHub token for the org in the request path.
#
# Wired for github.com with `useHttpPath`, so git passes the repo path; we route on its
# first segment (the org) to `devcred get github/<org>`. Only answers for github.com;
# store/erase are no-ops (tokens live only on the shelf). Opt out with DEVCRED_GIT_HELPER=off.
#
set -euo pipefail

[ "${1:-}" = "get" ] || exit 0
[ "${DEVCRED_GIT_HELPER:-on}" != off ] || exit 0

host="" path=""
while IFS='=' read -r key value; do
  case "$key" in
    host) host="$value" ;;
    path) path="$value" ;;
    "") break ;; # blank line terminates the request
  esac
done
[ "$host" = "github.com" ] || exit 0

# org = first path segment ("owner/repo.git" with useHttpPath; empty otherwise → default).
org="${path%%/*}"
[ -n "$org" ] || org="${GH_DEFAULT_ORG:-}"
[ -n "$org" ] || exit 0

token="$(devcred get "github/$org" 2>/dev/null || true)"
[ -n "$token" ] || exit 0

printf 'username=x-access-token\n'
printf 'password=%s\n' "$token"
