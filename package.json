{
  "name": "@twin-digital/monorepo",
  "version": "0.0.0",
  "description": "Monorepo for the Pegasus",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "artifact": "turbo run artifact",
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write --ignore-path .gitignore --ignore-path .prettierignore .",
    "format:check": "prettier --check --ignore-path .gitignore --ignore-path .prettierignore .",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:deps": "sherif",
    "predev": "turbo run build",
    "prepare": "husky tooling/husky || true",
    "publish-packages": "turbo run build && changeset publish",
    "squash": "node tooling/scripts/bin/squash.js",
    "sync": "repo-kit sync",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "typecheck": "turbo run typecheck",
    "update-readme": "repo-kit update-readme",
    "watch": "turbo watch build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@twin-digital/repo-kit": "workspace:*",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "serverless": "catalog:",
    "sherif": "^1.11.1",
    "turbo": "^2.6.1",
    "typescript": "^6.0.0"
  },
  "author": "Sean Kleinjung <sean@twindigital.io>",
  "packageManager": "pnpm@10.34.1",
  "lint-staged": "tooling/config/lint-staged.config.js"
}
