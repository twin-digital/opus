#!/usr/bin/env bash
#
# SessionStart hook: pre-warm the GitHub token cache and report whether minting works.
#
# Auth is on-demand, not ambient: the `gh` wrapper (/usr/local/bin/gh) mints a token via AWS KMS
# when `gh` or git over HTTPS needs one, gated by the ambient AWS session. There is no per-Bash
# GH_TOKEN to set. This hook just (a) warms the cache so the first gh/git call is instant and
# (b) surfaces a mint failure (expired AWS/SSO creds, missing kms:Sign, …) up front rather than
# mid-task.
#
# SessionStart doesn't reliably surface `exit 2` + stderr, so we emit JSON: `systemMessage`
# (user-visible) + `additionalContext` (model-visible), and exit 0.
set -euo pipefail

# JSON-escape a string: collapse control chars (0x00-0x1f) to spaces, then escape backslash and
# doublequote. Order matters: control chars first, backslash before quote.
_json_escape() {
  printf '%s' "$1" | tr '\000-\037' ' ' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

# emit <systemMessage|""> <additionalContext> — print SessionStart JSON and exit 0.
# An empty systemMessage omits the field (quiet, model-only context).
emit() {
  local sm="" ctx
  ctx=$(_json_escape "$2")
  if [ -n "$1" ]; then
    sm="\"systemMessage\":\"$(_json_escape "$1")\","
  fi
  printf '{%s"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' \
    "$sm" "$ctx"
  exit 0
}

# Surface credential problems now (vend loop stalled, sidecar down) instead of mid-task.
if err="$(/usr/local/bin/gh-token-seed 2>&1)"; then
  emit "" "gh and git (HTTPS) authenticate on demand via the gh wrapper, serving the pre-scoped App token the admin sidecar vends to /creds. Use gh/git normally; for a raw token in a script, run: gh-token-get."
else
  emit \
    "⚠️ GitHub shelf token unavailable — gh/git HTTPS auth will not work until vending resumes. ${err}" \
    "No vended GitHub token is available (${err}); gh and git-over-HTTPS will be unauthenticated. Warn the user before any operation that needs GitHub access. Likely cause: the vend loop stalled — a human must refresh SSO in the admin sidecar (see /workspace/.devcontainer/README.md)."
fi
