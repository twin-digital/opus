{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "env": {
    "APP_ID": "3967552",
    "GH_TOKEN_REPOS": "[\"opus\"]",
    "GH_TOKEN_PERMS": "{\"contents\":\"write\",\"pull_requests\":\"write\"}",
