# Minecraft dev Bedrock server overrides.
# Consumed by nodejs/minecraft/dev-bedrock-server/compose.yaml — dev.mjs passes
# this file via --env-file automatically (compose never auto-loads a .env from
# the cwd). Copy to `.env` (gitignored) and adjust. Every key is
# optional — compose falls back to a sensible default (see compose.yaml) when a
# key is unset, so the server boots with no .env at all.

# Pinned world seed for a reproducible dev world. Leave unset (or omit .env
# entirely) for a random world.
MINECRAFT_LEVEL_SEED=-4879002305207299781

# Bedrock server version — match prod so @minecraft/server lines up.
MINECRAFT_VERSION=1.26.31.1

# Other knobs (defaults shown) — uncomment to override:
# MINECRAFT_LEVEL_NAME=dev
# MINECRAFT_SERVER_NAME=dev-behavior-packs
# MINECRAFT_DIFFICULTY=normal
# MINECRAFT_GAMEMODE=survival
# MINECRAFT_ALLOW_CHEATS=true
# MINECRAFT_ALLOW_LIST=false
# MINECRAFT_DEFAULT_PLAYER_PERMISSION_LEVEL=operator
# MINECRAFT_CONTENT_LOG_CONSOLE_OUTPUT_ENABLED=true
