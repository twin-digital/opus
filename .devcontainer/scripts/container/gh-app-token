#!/usr/bin/env bash
#
# gh-app-token — mint a scoped GitHub App installation token, signing the App JWT with AWS KMS.
#
# The App private key lives in KMS (imported, non-extractable). We build the JWT, sign
# header.payload via `aws kms sign` using the container's AMBIENT AWS credentials, then exchange
# the JWT for a scoped ~1h installation token. Output: "<exp_epoch> <token>".
#
# The human-in-the-loop gate is your AWS/SSO session: minting works while those creds are valid,
# and stops when they expire/are revoked. Scope the creds (ideally a role whose only permission
# is kms:Sign on the one key) so an exfiltrated cred can do no more than mint these tokens.
#
# Config (non-secret) comes from the environment — set in devcontainer.json `containerEnv`, so the
# terminal and agents both have it:
#   APP_ID  INSTALLATION_ID  KMS_KEY_ID(alias|id|arn)  GH_TOKEN_REPOS(json)  GH_TOKEN_PERMS(json)
#
# Requires: aws, openssl, curl, jq.
#
set -euo pipefail
umask 077

log() { logger -t gh-app-token -- "$*" 2>/dev/null || true; }
die() { echo "gh-app-token: $*" >&2; log "ERROR: $*"; exit 1; }

: "${APP_ID:?set APP_ID}"
: "${INSTALLATION_ID:?set INSTALLATION_ID}"
: "${KMS_KEY_ID:?set KMS_KEY_ID (alias/key-id/arn)}"
# Empty/unset => OMIT that field from the request. Omitting `permissions` grants the App
# installation's FULL permission set; omitting `repositories` grants every repo it's installed on.
# Scope is managed App-side (the App's granted permissions / installed repos are the ceiling);
# set these only to narrow BELOW that ceiling.
REPOS_JSON="${GH_TOKEN_REPOS:-}"
PERMS_JSON="${GH_TOKEN_PERMS:-}"
for b in aws openssl curl jq date; do command -v "$b" >/dev/null || die "missing dependency: $b"; done

b64url() { openssl base64 -A | tr '+/' '-_' | tr -d '='; }

# NB: publish.yaml inlines this same JWT→KMS→exchange (a CI step can't source this container
# script). Keep the two in sync; if this logic changes a third time, take a hard look at
# consolidating them.
# ── build JWT (RS256), sign header.payload with KMS ──────────────────────────
now=$(date +%s)
header='{"alg":"RS256","typ":"JWT"}'
payload=$(printf '{"iat":%d,"exp":%d,"iss":"%s"}' "$((now - 60))" "$((now + 480))" "$APP_ID")
signing_input="$(printf '%s' "$header" | b64url).$(printf '%s' "$payload" | b64url)"

msg=$(mktemp); trap 'rm -f "$msg"' EXIT
printf '%s' "$signing_input" > "$msg"
# RS256 == RSASSA_PKCS1_V1_5_SHA_256; MessageType RAW => KMS hashes the input itself.
sig_b64=$(aws kms sign --key-id "$KMS_KEY_ID" --message "fileb://$msg" --message-type RAW \
            --signing-algorithm RSASSA_PKCS1_V1_5_SHA_256 --query Signature --output text) \
  || die "kms sign failed (AWS creds? kms:Sign on the key? KMS_KEY_ID correct?)"
sig=$(printf '%s' "$sig_b64" | openssl base64 -d -A | b64url)
jwt="${signing_input}.${sig}"

# ── exchange JWT -> scoped installation token ────────────────────────────────
# Include only the fields that are set; drop the rest so GitHub grants the App's full scope there.
body=$(jq -nc --argjson repos "${REPOS_JSON:-null}" --argjson perms "${PERMS_JSON:-null}" \
        '{repositories: $repos, permissions: $perms} | with_entries(select(.value != null))') \
  || die "invalid GH_TOKEN_REPOS / GH_TOKEN_PERMS"

resp=$(curl -sS -X POST \
  -H "Authorization: Bearer $jwt" \
  -H "Accept: application/vnd.github+json" \
  -H "X-GitHub-Api-Version: 2022-11-28" \
  "https://api.github.com/app/installations/${INSTALLATION_ID}/access_tokens" \
  -d "$body" -w $'\n%{http_code}') || die "request to GitHub failed"

code=${resp##*$'\n'}; json=${resp%$'\n'*}
# Only surface .message — never the whole body (a misparsed 201 body would hold the token).
[ "$code" = "201" ] || die "GitHub $code: $(printf '%s' "$json" | jq -r '.message // "unknown error"' 2>/dev/null)"
token=$(printf '%s' "$json" | jq -r '.token // empty')
[ -n "$token" ] || die "no token in response"
exp_iso=$(printf '%s' "$json" | jq -r '.expires_at')
exp_epoch=$(date -d "$exp_iso" +%s 2>/dev/null || echo "$((now + 3600))")

log "minted repos=${REPOS_JSON:-<all-installed>} perms=${PERMS_JSON:-<full-app-grant>} exp=${exp_iso}"
printf '%s %s\n' "$exp_epoch" "$token"
