#!/usr/bin/env bash
#
# import-app-private-key <path-to-pem> [--alias alias/NAME]
#
# Imports a GitHub App RSA private key into AWS KMS as a NON-EXTRACTABLE asymmetric signing key,
# using the container's ambient AWS credentials. Automates: PKCS#8 conversion, key creation
# (EXTERNAL origin, SIGN_VERIFY), wrapping with RSA_AES_KEY_WRAP_SHA_256, and import.
#
# Prints the resulting key ARN on stdout (everything else on stderr). After it succeeds, put a key
# reference (the alias) + your App/Installation IDs into `containerEnv`, grant kms:Sign on the key
# to your role, and DELETE the local .pem — the key is no longer needed (and now non-extractable).
#
# One-time setup. Requires: aws, openssl, jq, base64, od. AWS creds need (for this run):
#   kms:CreateKey, kms:CreateAlias, kms:GetParametersForImport, kms:ImportKeyMaterial, kms:DescribeKey
#
set -euo pipefail
umask 077

PEM="" ALIAS="${KMS_ALIAS:-alias/github-app-signer}"
while [ $# -gt 0 ]; do
  case "$1" in
    --alias) ALIAS="${2:?}"; shift 2 ;;
    -h|--help) echo "usage: import-app-private-key <path-to-pem> [--alias alias/NAME]" >&2; exit 0 ;;
    -*) echo "unknown option: $1" >&2; exit 2 ;;
    *) PEM="$1"; shift ;;
  esac
done
[ -n "$PEM" ]  || { echo "usage: import-app-private-key <path-to-pem> [--alias alias/NAME]" >&2; exit 2; }
[ -r "$PEM" ]  || { echo "cannot read pem: $PEM" >&2; exit 1; }
for b in aws openssl jq base64 od; do command -v "$b" >/dev/null || { echo "missing dependency: $b" >&2; exit 1; }; done

WORK="$(mktemp -d)"
trap 'find "$WORK" -type f -exec shred -u {} + 2>/dev/null || true; rm -rf "$WORK"' EXIT
cd "$WORK"

say() { echo "import-app-private-key: $*" >&2; }

# 0. detect RSA size -> KMS key spec
bits=$(openssl rsa -in "$PEM" -noout -text 2>/dev/null \
        | sed -n 's/.*Private-Key: (\([0-9]\{3,\}\) bit.*/\1/p' | head -1)
case "${bits:-}" in
  2048) SPEC=RSA_2048 ;; 3072) SPEC=RSA_3072 ;; 4096) SPEC=RSA_4096 ;;
  *) echo "not a supported RSA private key (size=${bits:-unknown})" >&2; exit 1 ;;
esac
say "${bits}-bit RSA -> $SPEC"

# 1. unencrypted PKCS#8 DER (KMS import format)
openssl pkcs8 -topk8 -inform PEM -outform DER -in "$PEM" -out key.der -nocrypt

# 2. create the KMS key (external origin, sign-only) + alias
KEY_ID=$(aws kms create-key --key-spec "$SPEC" --key-usage SIGN_VERIFY --origin EXTERNAL \
          --description "GitHub App JWT signer" --query KeyMetadata.KeyId --output text)
say "created key $KEY_ID"
aws kms create-alias --alias-name "$ALIAS" --target-key-id "$KEY_ID" 2>/dev/null \
  || aws kms update-alias --alias-name "$ALIAS" --target-key-id "$KEY_ID"
say "alias $ALIAS"

# 3. wrapping public key + import token (valid 24h)
aws kms get-parameters-for-import --key-id "$KEY_ID" \
  --wrapping-algorithm RSA_AES_KEY_WRAP_SHA_256 --wrapping-key-spec RSA_4096 --output json > params.json
jq -r .PublicKey   params.json | base64 -d > wrap.der
jq -r .ImportToken params.json | base64 -d > token.bin
openssl pkey -pubin -inform DER -in wrap.der -out wrap.pem

# 4. wrap the material (RSA_AES envelope: AES-wrap the key, RSA-OAEP-wrap the AES key)
openssl rand -out aes.bin 32
openssl enc -id-aes256-wrap-pad -K "$(od -An -v -tx1 < aes.bin | tr -d ' \n')" -iv A65959A6 \
  -in key.der -out mat.bin
openssl pkeyutl -encrypt -in aes.bin -out aeswrap.bin -pubin -inkey wrap.pem \
  -pkeyopt rsa_padding_mode:oaep -pkeyopt rsa_oaep_md:sha256 -pkeyopt rsa_mgf1_md:sha256
cat aeswrap.bin mat.bin > blob.bin          # RSA-wrapped AES key FIRST, then wrapped material

# 5. import
aws kms import-key-material --key-id "$KEY_ID" \
  --encrypted-key-material fileb://blob.bin --import-token fileb://token.bin \
  --expiration-model KEY_MATERIAL_DOES_NOT_EXPIRE >/dev/null
say "imported key material"

ARN=$(aws kms describe-key --key-id "$KEY_ID" --query KeyMetadata.Arn --output text)
{
  echo
  echo "✓ KMS signing key ready."
  echo "    KMS_KEY_ID=$ARN"
  echo "    alias=$ALIAS"
  echo
  echo "Next: put APP_ID + INSTALLATION_ID + KMS_KEY_ID (the alias above) in devcontainer.json"
  echo "containerEnv, grant kms:Sign on this key to your role, then 'shred -u ${PEM}'."
} >&2

printf '%s\n' "$ARN"     # machine-readable
