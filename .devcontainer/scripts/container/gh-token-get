#!/usr/bin/env bash
#
# gh-token-get — print a currently-valid GitHub token, re-minting via KMS when stale.
#
# Called by the `gh` wrapper (and thus by git, via `gh auth git-credential`) whenever gh/git needs a
# token — so it MUST be cheap on the hot path: read the cache, and only mint (KMS + GitHub API) when
# the cached token is near expiry. On any failure it prints nothing -> the caller is simply
# unauthenticated (fail-open). Minting works whenever the ambient AWS creds are valid.
#
set -euo pipefail

CACHE="${GH_TOKEN_CACHE:-${XDG_RUNTIME_DIR:-/tmp}/gh-token.$(id -u)}"
SKEW="${GH_TOKEN_SKEW:-300}"   # refresh when < 5 min remaining
now=$(date +%s)

emit_if_fresh() {
  local line exp tok
  line="$(cat "$CACHE" 2>/dev/null || true)"; [ -n "$line" ] || return 1
  exp="${line%% *}"; tok="${line#* }"
  [ -n "$exp" ] && [ "$exp" -gt "$((now + SKEW))" ] 2>/dev/null || return 1
  printf '%s' "$tok"; return 0
}

# hot path: valid cached token, no network
emit_if_fresh && exit 0

# stale: re-mint under a lock so concurrent Bash calls don't stampede KMS/GitHub
exec 9>"${CACHE}.lock" 2>/dev/null || { emit_if_fresh || true; exit 0; }
flock -w 15 9 2>/dev/null || { emit_if_fresh || true; exit 0; }
emit_if_fresh && exit 0   # someone minted while we waited

line="$(/usr/local/bin/gh-app-token 2>/dev/null)" || { emit_if_fresh || true; exit 0; }
case "$line" in
  [0-9]*\ *) umask 077; printf '%s' "$line" > "$CACHE"; printf '%s' "${line#* }" ;;
  *) emit_if_fresh || true ;;
esac
