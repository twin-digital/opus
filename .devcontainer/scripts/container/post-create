#!/usr/bin/env bash
set -euo pipefail

LOG_DIR="/workspace/opus/.devcontainer/logs"
mkdir -p "$LOG_DIR"
exec > >(tee "$LOG_DIR/container.log") 2>&1

echo "[post-create] Started."

for script in /usr/local/bin/post-create.d/*.sh; do
  [ -f "$script" ] || continue
  echo "[post-create] Running $(basename "$script")..." >&2
  bash "$script"
done

echo "[post-create] Complete."
